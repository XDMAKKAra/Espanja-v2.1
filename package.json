{
  "name": "spanish-beta",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "node scripts/build-bundle.mjs",
    "build:bundle": "node scripts/build-bundle.mjs",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:bug-scan": "playwright test tests/e2e-bug-scan.spec.js",
    "test:a11y": "playwright test tests/e2e-a11y.spec.js",
    "test:visual": "VISUAL_BASELINE=1 playwright test tests/e2e-visual.spec.js",
    "test:visual:update": "VISUAL_BASELINE=1 playwright test tests/e2e-visual.spec.js --update-snapshots",
    "check:sw": "node scripts/check-sw-cache-version.js",
    "bump:sw": "node scripts/check-sw-cache-version.js --fix",
    "validate:lessons": "node scripts/validate-lessons.mjs",
    "security:scan": "node scripts/security-scan.mjs",
    "lint": "eslint . --ext .js,.mjs",
    "audit:a11y": "pa11y-ci --config exercises/baselines/pa11y-ci.config.json --json > exercises/baselines/pa11y.json",
    "audit:lighthouse": "lighthouse http://localhost:3000/app.html --only-categories=performance,accessibility,best-practices --preset=desktop --output=json --output-path=exercises/baselines/lighthouse-app.json --chrome-flags=--headless --quiet",
    "audit:lighthouse:landing": "lighthouse http://localhost:3000/ --only-categories=performance,accessibility,best-practices --preset=desktop --output=json --output-path=exercises/baselines/lighthouse-landing.json --chrome-flags=--headless --quiet",
    "preview:capture": "node marketing/preview/scripts/capture.mjs",
    "preview:analyze-audio": "node marketing/preview/scripts/analyze-audio.mjs",
    "preview:studio": "cd marketing/preview && npm run dev",
    "preview:render": "cd marketing/preview && npm run build"
  },
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "posthog-js": "^1.369.2",
    "resend": "^6.12.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^9.17.0",
    "@fontsource/dm-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@playwright/test": "^1.59.1",
    "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.18",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^6.14.0",
    "@vitest/ui": "^4.1.4",
    "axe-core": "^4.11.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "lighthouse": "^13.1.0",
    "pa11y-ci": "^4.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
