{
  "name": "spanish-beta",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "echo 'No build step required'",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .js,.mjs",
    "audit:a11y": "pa11y-ci --config exercises/baselines/pa11y-ci.config.json --json > exercises/baselines/pa11y.json",
    "audit:lighthouse": "lighthouse http://localhost:3000/app.html --only-categories=performance,accessibility,best-practices --preset=desktop --output=json --output-path=exercises/baselines/lighthouse-app.json --chrome-flags=--headless --quiet",
    "audit:lighthouse:landing": "lighthouse http://localhost:3000/ --only-categories=performance,accessibility,best-practices --preset=desktop --output=json --output-path=exercises/baselines/lighthouse-landing.json --chrome-flags=--headless --quiet"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@sentry/node": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "posthog-js": "^1.369.2",
    "resend": "^6.12.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@vitest/ui": "^4.1.4",
    "axe-core": "^4.11.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "lighthouse": "^13.1.0",
    "pa11y-ci": "^4.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.4"
  }
}
