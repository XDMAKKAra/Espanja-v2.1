# Copy this file to .env and fill in real values.
# NEVER commit .env. Service-role keys grant full DB access — keep them
# server-side only. Anything marked "# optional" can be left empty in dev.

# ─── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon key — only used by tests/e2e-sr-review.spec.js for Supabase auth
# token exchange. Server code never needs it.
# optional
SUPABASE_ANON_KEY=

# ─── Pre-generated lessons (data/courses/*.json) ──────────────────────────
# false = runtime OpenAI -generointi (default)
# true = lue JSON-tiedostosta jos saatavilla, fallback OpenAI
USE_PREGENERATED_LESSONS=false

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
# Comma-separated list of origins allowed by CORS in production
# (e.g. "https://puheo.fi,https://www.puheo.fi"). Empty = no CORS allowlist.
ALLOWED_ORIGINS=

# ─── Pre-launch HTTP Basic Auth gate (middleware/basicAuth.js) ─────────────
# Set BOTH to enable a site-wide username/password prompt before anything
# else loads. Leave EITHER blank to disable the gate (dev default).
# optional
SITE_USERNAME=
SITE_PASSWORD=

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Puheo <noreply@yourdomain.com>

# ─── Payments (Stripe — wired in L-STRIPE-1, currently placeholder) ───────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# STRIPE_SUMMER_PRICE_ID=

# ─── Cron ──────────────────────────────────────────────────────────────────
CRON_SECRET=your-secret-here

# ─── Web Push (generate with: npx web-push generate-vapid-keys) ────────────
# optional
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Error tracking (Sentry) ───────────────────────────────────────────────
# optional
SENTRY_DSN=

# ─── Feature flags ─────────────────────────────────────────────────────────
# Pause AI generation during YO-koe week (lib/featureFlags.js).
# optional
EXAM_WEEK=
# Force-disable OpenAI calls (returns cached/stub data).
# optional
OPENAI_DISABLED=

# ─── Test accounts (comma-separated email lists) ───────────────────────────
# TEST_PRO_EMAILS: emails that bypass paywall checks and are always treated
# as Pro by middleware/auth.js. Use for dev testing and demos. These
# accounts still need to exist in auth.users (create via the normal signup
# flow) — the env var only flips their Pro status, it does not create the
# account. Example: testpro123@gmail.com,demo@example.com
# optional
TEST_PRO_EMAILS=

# TEST_FREE_EMAILS: emails forced to the free tier, overriding any real
# subscription. Handy for testing paywall UX on an account that would
# otherwise be Pro.
# optional
TEST_FREE_EMAILS=

# Legacy aliases for the two lists above. middleware/auth.js still reads
# these as fallback if the canonical names are missing. Prefer the
# canonical names; documented here only so the .env.example covers every
# var the code reads.
# optional
PRO_TEST_LIST=
# optional
FREE_TEST_LIST=

# ─── Test runner credentials (Playwright e2e specs) ────────────────────────
# Used by tests/e2e-*.spec.js. Tests skip themselves if these are unset.
# optional
TEST_USER_EMAIL=
# optional
TEST_USER_PASSWORD=
# optional
TEST_SIGNUP_EMAIL=
# optional
TEST_PRO_EMAIL=
# optional
TEST_PRO_PASSWORD=

# Playwright base URL override + visual-baseline enforcement flag.
# optional
BASE_URL=
# optional
VISUAL_BASELINE=

# ─── CI / build metadata ───────────────────────────────────────────────────
# CI script base ref for `npm run check:sw`.
# optional
CI_BASE_REF=
# Vercel sets these automatically; only override locally if needed.
# optional
GIT_SHA=
# optional
NODE_ENV=

# ─── Admin ─────────────────────────────────────────────────────────────────
# Comma-separated emails granted admin endpoints (routes/exercises.js).
# optional
ADMIN_EMAILS=
