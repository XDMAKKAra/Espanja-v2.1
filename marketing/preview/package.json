{
  "name": "puheo-preview",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion preview reel for Puheo",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "build": "remotion render src/index.ts PuheoPreviewVertical out/puheo-preview-vertical.mp4 && remotion render src/index.ts PuheoPreviewLandscape out/puheo-preview-landscape.mp4",
    "build:vertical": "remotion render src/index.ts PuheoPreviewVertical out/puheo-preview-vertical.mp4",
    "build:landscape": "remotion render src/index.ts PuheoPreviewLandscape out/puheo-preview-landscape.mp4"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.380",
    "@remotion/cli": "^4.0.380",
    "@remotion/renderer": "^4.0.380",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.380"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "playwright": "^1.59.1",
    "typescript": "^5.6.3"
  }
}
