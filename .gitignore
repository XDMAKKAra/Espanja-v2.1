# ==========================================================================
# Puheo .gitignore — GitHub sisältää VAIN sen mitä Vercel-deploy + ajava
# appi tarvitsee. Kaikki dev/sisäinen/Claude-roina pidetään lokaalina.
# Sääntö: jos tiedosto ei vaikuta tuotantokoodiin tai deployhyn -> tänne.
# ==========================================================================

# --- Salaisuudet & ympäristö ---
.env
.env.local
.env.*.local
.env.production
.env.development
.env.TARVITTAVAT-AVAIMET.txt
*.pem
*.key

# --- Riippuvuudet & OS ---
node_modules/
.DS_Store
*.log

# --- Build-artefaktien sourcemapit (bundlet itsessään committataan) ---
app.bundle.js.map
app.bundle.css.map
chunks/*.map

# --- Tietokanta-tiedostot (lokaali) ---
*.db
*.db-shm
*.db-wal

# --- Vercel / deploy-työkalut ---
.vercel
.agents/

# ==========================================================================
# DEV / TESTIT / TYÖKALUT — ei koskaan GitHubiin
# ==========================================================================
tests/
test-results/
playwright-report/
coverage/
coverage
playwright.config.js
vitest.config.js
.github/

# scripts/ on dev-skriptejä — vain build tarvitsee kaksi tiedostoa
scripts/*
!scripts/build-bundle.mjs
!scripts/bundle-entry.css

# ==========================================================================
# CLAUDE / AGENT-KONFIGURAATIO — lokaali, ei GitHubiin
# ==========================================================================
.claude/
.continue/
.superpowers/
.ruflo/
.impeccable
skills/
skills-lock.json
spanish/
graphify-out/
CLAUDE.md

# ==========================================================================
# SISÄISET DOKUMENTIT & SUUNNITELMAT — lokaali, ei GitHubiin
# ==========================================================================
docs/
plans/
agent-prompts/
cost/
testing/
fixes/
viewport-fix/
AGENT_PROMPT_STANDARDS.md
AGENT_STATE.md
API.md
AUDIT_LIVE_DASHBOARD.md
BUGS.md
CHANGELOG.md
CONVENTIONS.md
CURRICULUM_SPEC.md
DESIGN.md
IMPROVEMENTS.md
IMPROVEMENTS-archive.md
LANDING_PLAN.md
PLAN.md
PRODUCT.md
REMONTTI_AUDIT.md
ROADMAP.md
_COMMUNITY_*.md

# ==========================================================================
# MARKKINOINTI / SOME -SISÄLTÖMOOTTORI — raskaat assetit, lokaali
# ==========================================================================
social/
marketing/preview/public/captures/
marketing/preview/out/
marketing/preview/node_modules/
screenshots/
tmp/
audit/
audit-screens/
ui-ux/
training/
_audit/
*-prompt.md

# --- Editori / muu lokaali ---
.vscode/
.obsidian/
.aider*
